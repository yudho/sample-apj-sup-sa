# AWS region for Bedrock. Make sure your chosen models are available here.
AWS_REGION=us-east-1

# Hard cap on iterations. Conceptual: "how many full review cycles". The swarm's
# max_handoffs and max_iterations are set to 10 * this value to give the agents
# room to consult each other within a cycle without immediately tripping the cap.
BUILDINGO_MAX_ITERATIONS=3

# Per-node and overall timeouts (seconds).
# node_timeout: max time a single agent turn can take. 10 minutes is generous;
# any turn taking longer is wedged, not working. Saves tokens on stuck turns.
BUILDINGO_NODE_TIMEOUT_SECONDS=300
BUILDINGO_EXECUTION_TIMEOUT_SECONDS=3600

# Cost budget (USD). The swarm aborts if estimated spend exceeds this value.
# Uses worst-case Opus pricing for the estimate, so actual spend may be lower.
BUILDINGO_MAX_COST_USD=20.0

# Per-agent Bedrock model IDs. Verify the exact inference-profile date suffixes
# in your account with `aws bedrock list-inference-profiles --region $AWS_REGION`
# and adjust if they differ.
#
# Default role-to-model mapping:
#   architect   → Opus 4.6    (deep upfront reasoning)
#   developer   → Sonnet 4.6  (most production code, most turns)
#   researcher  → Sonnet 4.6  (cheap and fast for lookups)
#   tester      → Sonnet 4.6  (mechanical verification)
#   reviewer    → Sonnet 4.6  (scoped review, cost-sensitive)
#   lead        → Sonnet 4.6  (decisive sign-off; cost-sensitive)
BUILDINGO_MODEL_ARCHITECT=global.anthropic.claude-opus-4-6-v1
BUILDINGO_MODEL_DEVELOPER=global.anthropic.claude-sonnet-4-6
BUILDINGO_MODEL_RESEARCHER=global.anthropic.claude-sonnet-4-6
BUILDINGO_MODEL_TESTER=global.anthropic.claude-sonnet-4-6
BUILDINGO_MODEL_REVIEWER=global.anthropic.claude-sonnet-4-6
BUILDINGO_MODEL_LEAD=global.anthropic.claude-sonnet-4-6
