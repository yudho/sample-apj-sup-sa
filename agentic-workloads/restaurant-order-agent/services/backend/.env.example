# AWS Configuration
AWS_REGION=us-west-2

# Restaurant API (your backend URL)
RESTAURANT_API_BASE=https://your-api-domain.example.com
RESTAURANT_API_KEY=your_api_key_here

# AWS SNS (for OTP SMS)
SNS_SENDER_ID=TastyApp

# JWT Authentication
# Generate a strong random secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=change-this-to-a-random-secret

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Bedrock model ID for the chat agent (cross-region inference profile)
CHAT_MODEL_ID=us.anthropic.claude-sonnet-4-6

# Demo customer phone number in E.164 format (used to seed the demo profile).
# Change this to your own number to test OTP end to end.
DEMO_PHONE_NUMBER=+14155552671

# AgentCore Runtime ARN (from `agentcore deploy` output)
AGENT_RUNTIME_ARN=arn:aws:bedrock-agentcore:REGION:ACCOUNT_ID:runtime/YOUR_RUNTIME_NAME
