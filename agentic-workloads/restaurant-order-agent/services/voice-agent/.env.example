# Deepgram API Key (for STT and TTS)
DEEPGRAM_API_KEY=your_deepgram_api_key_here

# AWS Region
AWS_REGION=us-west-2

# Bedrock model ID (cross-region inference profile)
LLM_MODEL_ID=us.anthropic.claude-sonnet-4-6

# AgentCore Memory ID (optional — memory features disabled if unset)
AGENTCORE_MEMORY_ID=your_memory_id_here

# Restaurant API / MCP Proxy URL
MCP_PROXY_URL=https://your-cloudfront-distribution.cloudfront.net

# Restaurant API Key
RESTAURANT_API_KEY=your_api_key_here
