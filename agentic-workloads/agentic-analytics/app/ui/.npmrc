# The Pipecat voice deps have a known peer-dependency conflict under npm 7+
# (@pipecat-ai/small-webrtc-transport wants client-js ~1.10 while
# @pipecat-ai/client-react pins an older client-js). They work fine together at
# runtime, so resolve peers the npm 6 way. This lets the workshop's plain
# `npm install` (Step 3.2) succeed without --legacy-peer-deps on the CLI.
legacy-peer-deps=true

# All UI dependencies are public npm packages — pin the public registry so the
# build never depends on a private/authenticated registry a developer's global
# ~/.npmrc might point at (e.g. an expired corporate CodeArtifact token would
# otherwise fail `npm install` here with E401).
registry=https://registry.npmjs.org/
