# --- Required: Deepgram does both speech-to-text and text-to-speech ---
DEEPGRAM_API_KEY=your_deepgram_key_here
# Optional: Deepgram Aura TTS voice (default: aura-2-thalia-en). Aura is English-focused.
# DEEPGRAM_TTS_VOICE=aura-2-thalia-en

# Region for Bedrock LLM inference + AgentCore. Sydney is supported.
AWS_REGION=ap-southeast-2

# AgentCore Gateway MCP endpoint (Aisle catalogue + cart/order tools).
GATEWAY_MCP_URL=https://<your-gateway-id>.gateway.bedrock-agentcore.ap-southeast-2.amazonaws.com/mcp

# --- AgentCore Memory (short-term turns + long-term user preferences) ---
# Set after running ./scripts/setup-memory.sh. Leave BLANK to run with memory
# fully DISABLED (the agent no-ops every memory call and runs normally).
MEMORY_ID=
# The shopper's long-term identity (actor_id). For the single-user demo this is a
# fixed value; a real deployment passes a per-user id in the /start payload.
DEMO_USER_ID=demo-user

# --- Optional: Tavus avatar. Leave both blank for an audio-only agent. ---
# The avatar turns on only when BOTH of these are set.
# TAVUS_API_KEY=your_tavus_key_here
# TAVUS_REPLICA_ID=your_tavus_replica_id_here

# --- Local development only (ignored at deployment by launch.sh) ---
# Set PIPECAT_LOCAL_DEV=1 and a real Daily room URL to run the bot locally:
#   PIPECAT_LOCAL_DEV=1 uv run agent/pipecat-agent.py -t daily -d
# PIPECAT_LOCAL_DEV=1
# DAILY_ROOM_URL=https://YOURDOMAIN.daily.co/YOURROOM
