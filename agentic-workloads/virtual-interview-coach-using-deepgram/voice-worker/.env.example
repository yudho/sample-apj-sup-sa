# Voice worker environment (copy to .env; never commit real values)

# Deepgram (STT + Aura TTS)
DEEPGRAM_API_KEY=

# Reply generator selection: agentcore | bedrock_direct
REPLY_PROVIDER=bedrock_direct

# AWS (Bedrock AgentCore / Bedrock Runtime / CloudWatch)
AWS_REGION=us-west-2
# AgentCore identifiers (populate when AgentCore is provisioned — from CFN outputs)
AGENTCORE_AGENT_ID=
AGENTCORE_AGENT_ALIAS_ID=
# Direct-Bedrock model id. NOTE: newer Claude (Sonnet/Haiku 4.x) require a cross-region
# INFERENCE PROFILE id (the "us." prefix), not the bare on-demand model id.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# F002 (G2): pinned Titan embedding model. Off the response_gap clock — offline bank embedding
# (bank/embed.py) + session-prep JD embedding only. A change forces a bank re-embed.
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0

# Postgres (G1 3-table slice; F002 extends it additively via python -m src.db_migrate)
DATABASE_URL=postgres://user:pass@localhost:5432/interviewcoach

# CloudWatch metric namespace
CW_METRIC_NAMESPACE=InterviewCoach/G1

# Endpointing silence threshold (ms) — tune against acceptance scenarios
STT_ENDPOINTING_MS=600

# Acoustic end-of-speech -> final transcript constant added to the real-loop response_gap
# (~267-286ms measured against Deepgram nova-2). Stated + overridable for an honest gate number.
STT_FINALIZATION_MS=280

# Latency strategy (F007): "processor" speaks an immediate lead-clause backchannel while the
# reply LLM generates concurrently, keeping the LLM off the response_gap critical path (the
# SC-001 PASS lever; see specs/007-pipecat-adoption/gate-decision.md). processor | native.
LEAD_CLAUSE_STRATEGY=processor

# Media-join token secret — MUST match the backend's VOICE_TOKEN_SECRET (the backend mints the
# short-lived HS256 voice_token; the worker verifies it). Use >=32 bytes. Never commit a real value.
VOICE_TOKEN_SECRET=

# Signaling server bind (the SPA POSTs its WebRTC offer to {media_endpoint}/offer)
SERVER_HOST=0.0.0.0
SERVER_PORT=8080

# STUN servers for the worker's RTCPeerConnection (comma-separated stun: URLs). REQUIRED when
# the worker runs on Fargate with a public IP: without STUN aiortc only offers its private VPC
# host candidate, which the browser cannot reach. Leave EMPTY for the same-host local loop /
# harness (host candidates work there). Example: stun:stun.l.google.com:19302
ICE_STUN_URLS=

# Local log file
LOG_FILE=voice-worker.log

# Verbose per-frame media diagnostics (inbound audio peak/bytes, Deepgram Results). Off in
# production; flip to true to debug the media plane (e.g. silent STT / no transcripts). true | false.
MEDIA_DEBUG=false
