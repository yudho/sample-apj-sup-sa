# Backend app API environment (copy to .env; never commit real values)

# Postgres (shared G1 slice)
DATABASE_URL=postgres://user:pass@localhost:5432/interviewcoach

# Cognito (JWT validation)
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=

# Voice media plane
MEDIA_ENDPOINT=wss://media.example.com
# Reply generator selection echoed onto each session: agentcore | bedrock_direct
REPLY_PROVIDER=agentcore

# Managed TURN provider (ephemeral credential minting) — populate for US3
TURN_PROVIDER=twilio
TURN_API_KEY=
TURN_API_SECRET=
STUN_URL=stun:stun.l.google.com:19302

# Short-lived voice join token signing
VOICE_TOKEN_SECRET=
VOICE_TOKEN_TTL_S=120

AWS_REGION=us-east-1

# --- Feature 002 (G2) personalization: all off the response_gap clock ---
# Bedrock Titan embedding model, pinned (used at session-prep to embed the JD once, and by the
# offline bank pipeline). A model change forces a bank re-embed (embedding_model is stored beside
# each vector). Titan Text Embeddings v2 outputs 1024-dim by default.
BEDROCK_EMBEDDING_MODEL_ID=amazon.titan-embed-text-v2:0
# S3 bucket (SSE-KMS) holding raw resume files — sole durable home for that PII alongside RDS
# (Constitution III). Provisioned in T003.
RESUME_BUCKET=
# KMS key id for SSE-KMS on the resume bucket; blank uses the bucket's default encryption.
RESUME_KMS_KEY_ID=
# Pinned rubric/tier-context version stamped on each personalized session (FR-215 / Principle II).
# F002 does not score, but records WHICH (difficulty, rubric_version) a session ran under so later
# cross-session comparison can account for rubric changes and never blend tiers. Bump on rubric change.
RUBRIC_VERSION=g2-2026.1
